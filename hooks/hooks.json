{
  "Stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/hooks/token-count.sh",
          "timeout": 5
        }
      ]
    }
  ],
  "StopFailure": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/hooks/token-count.sh",
          "timeout": 5
        }
      ]
    }
  ]
}
